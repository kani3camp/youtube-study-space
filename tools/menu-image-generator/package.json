{
	"name": "menu-image-generator",
	"version": "1.0.0",
	"packageManager": "pnpm@10.4.0",
	"description": "Firestoreのmenuコレクションからメニュー表画像を生成するCLIツール",
	"main": "dist/index.js",
	"scripts": {
		"build": "tsc",
		"generate": "tsc && node dist/index.js",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format .",
		"format:fix": "biome format --write ."
	},
	"license": "SEE LICENSE IN LICENSE",
	"dependencies": {
		"dotenv": "^17.4.2",
		"firebase-admin": "^13.10.0",
		"puppeteer": "^24.42.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@types/node": "^25.9.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"typescript": "^6.0.3"
	}
}
