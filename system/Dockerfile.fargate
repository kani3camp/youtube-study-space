FROM golang:1.26@sha256:32c0e6e5c4f6707717051091b4d0b077464a679eaab563e11474efc5328e2aa5 AS build
WORKDIR /src

# 依存関係キャッシュを効かせるために先に go.mod/go.sum だけコピー
COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod go mod download

# アプリコードをコピー
COPY . .

# Build for linux/${GOARCH}, static, no cgo
ARG GOARCH=arm64
ARG BUILD_TARGET=./cmd/batch
ENV CGO_ENABLED=0 GOOS=linux GOARCH=${GOARCH} GOCACHE=/root/.cache/go-build
RUN --mount=type=cache,target=/go/pkg/mod \
  --mount=type=cache,target=/root/.cache/go-build \
  go build -tags timetzdata -trimpath -ldflags="-s -w" -o /out/batch ${BUILD_TARGET}

FROM gcr.io/distroless/static-debian12:nonroot@sha256:d093aa3e30dbadd3efe1310db061a14da60299baff8450a17fe0ccc514a16639
WORKDIR /app
ENV TZ=Asia/Tokyo
COPY --from=build /out/batch /app/batch
USER nonroot:nonroot
ENTRYPOINT ["/app/batch"]
